{
  "name": "createsuite",
  "version": "0.1.0",
  "description": "Orchestrated swarm system for OpenCode agents with git-based task tracking",
  "main": "dist/index.js",
  "bin": {
    "createsuite": "./bin/createsuite.js",
    "cs": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:netlify": "mkdir -p public/docs && cp -R docs/. public/docs && cp README.md public/docs/PROJECT_README.md",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "postinstall": "node scripts/postinstall.js || true",
    "remotion:preview": "cd remotion && npx remotion preview src/index.ts",
    "remotion:render": "cd remotion && npx remotion render src/index.ts CreateSuiteTour ../public/tour.mp4",
    "remotion:render:agent-ui": "cd remotion && npx remotion render src/index.ts AgentUITour ../public/agent-ui-tour.mp4",
    "background:evaluate": "node scripts/capture_background_eval.js",
    "video:build": "npm run remotion:render",
    "video:build:agent-ui": "npm run remotion:render:agent-ui",
    "dev:all": "./scripts/dev.sh start",
    "dev:stop": "./scripts/dev.sh stop",
    "dev:status": "./scripts/dev.sh status"
  },
  "keywords": [
    "opencode",
    "agents",
    "orchestration",
    "swarm",
    "git",
    "task-tracking",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/prompts": "^2.4.9",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.22.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "remotion": "^4.0.448",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22"
  }
}
