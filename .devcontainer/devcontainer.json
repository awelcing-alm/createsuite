{
  "name": "CreateSuite Optimal Container",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "elixir-lsp.elixir-ls",
        "phoenixframework.phoenix",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "elixirLS.suggestSpecs": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "containerEnv": {},
  "remoteUser": "root",
  "postCreateCommand": "bash ./.devcontainer/post-create.sh",
  "postStartCommand": "bash ./.devcontainer/post-start.sh",
  "waitFor": "postCreateCommand",
  "forwardPorts": [3001, 4000, 5173, 5432],
  "mounts": [
    "source=cs-npm-cache,target=/root/.npm,type=volume",
    "source=cs-mix-cache,target=/root/.mix,type=volume",
    "source=cs-cargo-registry,target=/root/.cargo/registry,type=volume",
    "source=cs-cache,target=/root/.cache,type=volume"
  ],
  "portsAttributes": {
    "3001": {
      "label": "Legacy Express Server",
      "onAutoForward": "notify"
    },
    "4000": {
      "label": "Phoenix Backend",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite Frontend",
      "onAutoForward": "openBrowser"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "notify"
    }
  }
}
